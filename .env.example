# Copy to .env and fill in. .env is git-ignored.

# Flask
FLASK_CONFIG=dev            # dev | test | prod
# REQUIRED in prod — the app refuses to boot without it. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database (defaults to instance/cernyfoot.db if unset)
# DATABASE_URL=sqlite:////absolute/path/to/cernyfoot.db

# Localisation
TIMEZONE=Europe/Bratislava
LANGUAGE=sk

# Match timing — SINGLE source of truth (replaces the 5 hard-coded cutoffs
# in the original app). Local time, HH:MM.
SIGNUP_DEADLINE=18:45       # after this, sign-up/sign-out for that day's match closes
MATCH_LOCK=19:05            # after this, the match counts as played in stats

# Auth guardrail (per owner decision D3: no password-strength rules)
LOGIN_RATELIMIT=10 per minute
